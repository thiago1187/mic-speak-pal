# Copie este arquivo para `.env` e preencha as chaves (o `.env` não é commitado).
# Em produção, configure as MESMAS variáveis no painel da Vercel
# (Project → Settings → Environment Variables) e faça um redeploy.

# Chave da API do HeyGen / LiveAvatar (cria a sessão do avatar).
HEYGEN_API_KEY=

# Chave da API do Deepgram (transcrição da voz no navegador, motor "Deepgram").
DEEPGRAM_API_KEY=

# Chave da API do Recall.ai (opcional — só pra Camada 3, avatar dentro do Google Meet).
RECALL_API_KEY=

# Senha ÚNICA de acesso ao app. Se definida, exige login (tela + APIs protegidas).
# Se ficar vazia/ausente, o login fica DESATIVADO (app abre sem senha).
APP_PASSWORD=

